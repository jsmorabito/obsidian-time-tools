{
	"name": "obsidian-time-manager",
	"version": "0.1.0",
	"description": "Time-aware note management for Obsidian: periodic notes plus a multi-note editor view.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint ."
	},
	"keywords": [
		"obsidian",
		"plugin",
		"daily-notes",
		"periodic-notes",
		"time-management"
	],
	"license": "MIT",
	"devDependencies": {
		"@types/node": "^16.11.6",
		"esbuild": "0.25.5",
		"esbuild-svelte": "^0.9.3",
		"eslint-plugin-obsidianmd": "0.1.9",
		"globals": "14.0.0",
		"svelte": "^4.2.19",
		"svelte-check": "^3.8.0",
		"svelte-preprocess": "^5.1.4",
		"tslib": "2.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "8.35.1",
		"@eslint/js": "9.30.1",
		"jiti": "2.6.1"
	},
	"dependencies": {
		"obsidian": "latest",
		"monkey-around": "^2.3.0",
		"svelte-inview": "^4.0.2"
	}
}
